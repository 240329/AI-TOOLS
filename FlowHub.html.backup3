<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HR Flow - 智能流程推送系统</title>
    <!-- 引入字体图标 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
	:root {
            --glass-bg: rgba(255, 255, 255, 0.05);
            --glass-border: rgba(255, 255, 255, 0.1);
            --glass-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
            --primary-color: #2dd4bf; /* 现代青色 */
            --secondary-color: #3b82f6; /* 商务蓝 */
            --text-main: #ffffff;
            --text-muted: #94a3b8;
        }

        body {
            background-color: #030712;
            color: var(--text-main);
            height: 100vh;
            overflow: hidden;
            display: flex;
            justify-content: center;
            align-items: center;
            position: relative;
        }

        .bg-shapes {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            overflow: hidden;
            z-index: -1;
            background: radial-gradient(circle at top right, #111827, #030712);
        }

        .shape {
            position: absolute;
            filter: blur(100px);
            border-radius: 50%;
            animation: float 20s infinite alternate linear;
            opacity: 0.4;
        }

        .shape-1 { width: 500px; height: 500px; background: #1e40af; top: -10%; left: -5%; }
        .shape-2 { width: 600px; height: 600px; background: #0f766e; bottom: -10%; right: -5%; }
        .shape-3 { width: 400px; height: 400px; background: #312e81; top: 30%; left: 30%; }

        @keyframes float {
            0% { transform: translate(0, 0) scale(1); }
            50% { transform: translate(100px, 50px) scale(1.2); }
            100% { transform: translate(-50px, 100px) scale(0.8); }
        }

        /* 核心布局结构 */
        .app-container {
            width: 90%;
            height: 90%;
            max-width: 1400px;
            display: flex;
            background: var(--glass-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            box-shadow: var(--glass-shadow);
            overflow: hidden;
            animation: slideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            opacity: 0;
            transform: translateY(30px);
        }

        @keyframes slideUp {
            to { opacity: 1; transform: translateY(0); }
        }

        /* 侧边栏 */
        .sidebar {
            width: 260px;
            border-right: 1px solid var(--glass-border);
            padding: 30px 20px;
            display: flex;
            flex-direction: column;
        }

        .logo {
            font-size: 24px;
            font-weight: bold;
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 50px;
            background: linear-gradient(to right, var(--primary-color), var(--secondary-color));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .nav-item {
            padding: 15px 20px;
            margin-bottom: 10px;
            border-radius: 12px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 15px;
            font-size: 16px;
            color: var(--text-muted);
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .nav-item:hover {
            color: var(--text-main);
            background: rgba(255, 255, 255, 0.05);
            transform: translateX(5px);
        }

        .nav-item.active {
            color: var(--text-main);
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid var(--glass-border);
            box-shadow: inset 0 0 10px rgba(255, 255, 255, 0.05);
        }

        .nav-item.active::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            height: 100%;
            width: 4px;
            background: linear-gradient(to bottom, var(--primary-color), var(--secondary-color));
        }

        /* 主内容区 */
        .main-content {
            flex: 1;
            padding: 40px;
            overflow-y: auto;
            position: relative;
        }

        /* 页面视图切换 */
        .view-section {
            display: none;
            animation: fadeIn 0.5s ease forwards;
        }

        .view-section.active {
            display: block;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
        }

        .header h1 {
            font-size: 28px;
            font-weight: 600;
        }

        .user-profile {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .avatar {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            display: flex;
            justify-content: center;
            align-items: center;
            font-weight: bold;
            box-shadow: 0 0 15px rgba(0, 242, 254, 0.4);
        }

        /* 卡片面板通用样式 */
        .glass-card {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--glass-border);
            border-radius: 20px;
            padding: 30px;
            margin-bottom: 30px;
            transition: transform 0.3s, box-shadow 0.3s;
        }

        .glass-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
            background: rgba(255, 255, 255, 0.06);
        }

        /* 上传拖拽区域 */
        .upload-area {
            border: 2px dashed rgba(255, 255, 255, 0.2);
            border-radius: 16px;
            padding: 50px 20px;
            text-align: center;
            transition: all 0.3s ease;
            cursor: pointer;
            background: rgba(0, 0, 0, 0.1);
        }

        .upload-area:hover, .upload-area.dragover {
            border-color: var(--primary-color);
            background: rgba(0, 242, 254, 0.05);
            box-shadow: inset 0 0 20px rgba(0, 242, 254, 0.1);
        }

        .upload-area i {
            font-size: 48px;
            color: var(--primary-color);
            margin-bottom: 20px;
            transition: transform 0.3s;
        }

        .upload-area:hover i {
            transform: scale(1.1) translateY(-5px);
        }

        .upload-area h3 { margin-bottom: 10px; font-weight: 500; }
        .upload-area p { color: var(--text-muted); font-size: 14px; margin-bottom: 20px; }

        /* 按钮样式 */
        .btn {
            background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));
            border: none;
            padding: 12px 30px;
            border-radius: 30px;
            color: white;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 5px 15px rgba(0, 242, 254, 0.3);
            display: inline-flex;
            align-items: center;
            gap: 10px;
        }

        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(0, 242, 254, 0.5);
            filter: brightness(1.1);
        }

        /* 列表/表格样式 */
        .data-list {
            margin-top: 20px;
        }
        
        .list-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 20px;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            transition: background 0.3s;
            border-radius: 10px;
        }

        .list-item:hover {
            background: rgba(255, 255, 255, 0.05);
        }

        .item-info h4 { font-size: 16px; margin-bottom: 5px; }
        .item-info p { font-size: 13px; color: var(--text-muted); }
        .badge {
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 12px;
            background: rgba(0, 242, 254, 0.1);
            color: var(--primary-color);
            border: 1px solid rgba(0, 242, 254, 0.3);
        }

        /* 数据概览小卡片 (Grid) */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: linear-gradient(135deg, rgba(255,255,255,0.05), rgba(255,255,255,0.01));
            padding: 25px;
            border-radius: 20px;
            border: 1px solid var(--glass-border);
            position: relative;
            overflow: hidden;
        }

        .stat-card::after {
            content: '\f080';
            font-family: 'Font Awesome 6 Free';
            font-weight: 900;
            position: absolute;
            right: -10px;
            bottom: -20px;
            font-size: 80px;
            opacity: 0.05;
        }

        .stat-card:nth-child(2)::after { content: '\f0c0'; }
        .stat-card:nth-child(3)::after { content: '\f1d8'; }

        .stat-value { font-size: 36px; font-weight: bold; margin-top: 10px; color: var(--primary-color); }

        /* 自定义滚动条 */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.2); border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.3); }

    </style>
</head>
<body>

    <!-- 动态背景层 -->
    <div class="bg-shapes">
        <div class="shape shape-1"></div>
        <div class="shape shape-2"></div>
        <div class="shape shape-3"></div>
    </div>

    <!-- 主体拟态玻璃容器 -->
    <div class="app-container">
        
        <!-- 左侧导航 -->
        <aside class="sidebar">
            <div class="logo">
                <i class="fa-solid fa-layer-group"></i>
                <span>FlowHub</span>
            </div>
            
            <nav>
                <div class="nav-item active" data-target="dashboard">
                    <i class="fa-solid fa-house"></i> 控制台概览
                </div>
                <div class="nav-item" data-target="knowledge">
                    <i class="fa-solid fa-book-open"></i> 流程知识库
                </div>
                <div class="nav-item" data-target="employees">
                    <i class="fa-solid fa-users"></i> 员工名单管理
                </div>
                <div class="nav-item" data-target="push-tasks">
                    <i class="fa-solid fa-paper-plane"></i> 定时推送任务
                </div>
            </nav>
        </aside>

        <!-- 右侧内容区 -->
        <main class="main-content">
            
            <header class="header">
                <h1 id="page-title">控制台概览</h1>
                <div class="user-profile">
                    <span>HR - 李主管</span>
                    <div class="avatar">李</div>
                </div>
            </header>

            <!-- 视图 1：控制台 -->
            <section id="dashboard" class="view-section active">
                <div class="stats-grid">
                    <div class="stat-card glass-card">
                        <p class="text-muted">已入库流程</p>
                        <div class="stat-value">128</div>
                    </div>
                    <div class="stat-card glass-card">
                        <p class="text-muted">本月待入职员工</p>
                        <div class="stat-value">45</div>
                    </div>
                    <div class="stat-card glass-card">
                        <p class="text-muted">自动推送任务</p>
                        <div class="stat-value">12</div>
                    </div>
                </div>
                
                <div class="glass-card">
                    <h3>最近执行的任务</h3>
                    <div class="data-list">
                        <div class="list-item">
                            <div class="item-info">
                                <h4>推送：IT设备申请及领用流程</h4>
                                <p>执行时间：今天 09:00 | 目标人数：15人</p>
                            </div>
                            <span class="badge" style="color: #00e676; border-color: rgba(0, 230, 118, 0.3); background: rgba(0, 230, 118, 0.1);">已完成</span>
                        </div>
                        <div class="list-item">
                            <div class="item-info">
                                <h4>推送：企业文化培训指南</h4>
                                <p>执行时间：明天 10:00 | 目标人数：45人</p>
                            </div>
                            <span class="badge" style="color: #ff9100; border-color: rgba(255, 145, 0, 0.3); background: rgba(255, 145, 0, 0.1);">等待执行</span>
                        </div>
                    </div>
                </div>
            </section>

            <!-- 视图 2：流程知识库 -->
            <section id="knowledge" class="view-section">
                <div class="glass-card">
                    <h3>导入流程清单</h3>
                    <p style="color: var(--text-muted); margin: 10px 0 20px;">支持导入 Excel / CSV 格式的流程标准文件。</p>
                    <div class="upload-area" id="drop-zone-flow">
                        <input type="file" id="file-input-flow" accept=".xlsx,.xls,.csv" style="display: none;">
                        <i class="fa-solid fa-cloud-arrow-up"></i>
                        <h3 id="upload-title-flow">点击或将文件拖拽到此处</h3>
                        <p id="upload-subtitle-flow">支持 .xlsx, .csv 文件，最大 50MB</p>
                        <p id="file-name-flow" style="display: none; color: var(--primary-color); margin-top: 10px;"></p>
                        <button class="btn" id="select-btn-flow"><i class="fa-solid fa-folder-open"></i> 选择文件</button>
                    </div>
                </div>

                <div class="glass-card">
                    <h3>当前系统流程清单 (节选)</h3>
                    <div class="data-list">
                        <div class="list-item">
                            <div class="item-info">
                                <h4>P-001: 新员工入职指引</h4>
                                <p>标签：入职, HR流程 | 适用对象：全体新员工</p>
                            </div>
                        </div>
                        <div class="list-item">
                            <div class="item-info">
                                <h4>P-002: 研发中心权限开通规范</h4>
                                <p>标签：IT, 研发 | 适用对象：研发部员工</p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- 视图 3：员工名单 -->
            <section id="employees" class="view-section">
                <div class="glass-card">
                    <h3>上传入职员工名单</h3>
                    <p style="color: var(--text-muted); margin: 10px 0 20px;">系统将自动识别部门与岗位，智能匹配对应流程。</p>
                    <div class="upload-area" id="upload-area-employee">
                        <input type="file" id="file-input-employee" accept=".xlsx,.xls,.csv" style="display: none;">
                        <i class="fa-solid fa-file-excel"></i>
                        <h3 id="upload-title-employee">拖拽员工名单表至此</h3>
                        <p id="upload-subtitle-employee">请确保包含：姓名、入职日期、部门、岗位、邮箱</p>
                        <p id="file-name-employee" style="display: none; color: var(--primary-color); margin-top: 10px;"></p>
                        <button class="btn" id="select-btn-employee"><i class="fa-solid fa-upload"></i> 上传名单</button>
                    </div>
                </div>
                
                <div class="glass-card">
                    <h3>待入职队列</h3>
                    <div class="data-list" id="employee-list">
                        <div class="list-item">
                            <div class="item-info">
                                <h4>暂无数据</h4>
                                <p>请上传员工名单</p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- 视图 4：定时推送任务 -->
            <section id="push-tasks" class="view-section">
                <!-- 飞书机器人状态 -->
                <div class="glass-card" style="padding: 15px 25px;">
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <div style="display: flex; align-items: center; gap: 12px;">
                            <i class="fa-brands fa-rocketchat" style="font-size: 24px; color: var(--primary-color);"></i>
                            <div>
                                <span style="font-weight: 500;">飞书应用机器人</span>
                                <span id="feishu-status" style="margin-left: 10px; padding: 3px 10px; border-radius: 12px; font-size: 12px; background: rgba(255,100,100,0.2); color: #ff6b6b;">未连接</span>
                            </div>
                        </div>
                        <button class="btn" style="padding: 8px 20px; font-size: 14px;" onclick="refreshFeishuStatus()">
                            <i class="fa-solid fa-rotate"></i> 刷新状态
                        </button>
                    </div>
                </div>

                <!-- 新建推送计划 -->
                <div class="glass-card">
                    <h3>新建推送计划</h3>
                    <p style="color: var(--text-muted); margin: 10px 0 20px;">通过飞书应用机器人自动触达入职员工</p>
                    
                    <div style="background: rgba(0,0,0,0.2); border-radius: 12px; padding: 20px; border: 1px solid rgba(255,255,255,0.05);">
                        <div style="margin-bottom: 15px;">
                            <label style="display: block; margin-bottom: 8px; color: var(--text-muted);">计划名称</label>
                            <input type="text" id="task-name" placeholder="例如：11月新员工入职流程推送" style="width: 100%; padding: 12px; border-radius: 8px; background: rgba(255,255,255,0.1); border: 1px solid var(--glass-border); color: white; outline: none; box-sizing: border-box;">
                        </div>
                        
                        <div style="display: flex; gap: 20px; margin-bottom: 15px;">
                            <div style="flex: 1;">
                                <label style="display: block; margin-bottom: 8px; color: var(--text-muted);">目标员工群</label>
                                <select id="task-target" style="width: 100%; padding: 12px; border-radius: 8px; background: rgba(255,255,255,0.1); border: 1px solid var(--glass-border); color: white; outline: none;">
                                    <option value="all" style="color: black;">全体新员工</option>
                                    <option value="department" style="color: black;">按部门选择</option>
                                </select>
                            </div>
                            <div style="flex: 1; display: none;" id="department-select-container">
                                <label style="display: block; margin-bottom: 8px; color: var(--text-muted);">选择部门</label>
                                <select id="task-department" style="width: 100%; padding: 12px; border-radius: 8px; background: rgba(255,255,255,0.1); border: 1px solid var(--glass-border); color: white; outline: none;">
                                    <option value="研发部" style="color: black;">研发部</option>
                                    <option value="财务部" style="color: black;">财务部</option>
                                    <option value="行政部" style="color: black;">行政部</option>
                                    <option value="市场部" style="color: black;">市场部</option>
                                </select>
                            </div>
                        </div>

                        <div style="display: flex; gap: 20px; margin-bottom: 15px;">
                            <div style="flex: 1;">
                                <label style="display: block; margin-bottom: 8px; color: var(--text-muted);">推送时间</label>
                                <input type="datetime-local" id="task-time" style="width: 100%; padding: 12px; border-radius: 8px; background: rgba(255,255,255,0.1); border: 1px solid var(--glass-border); color: white; outline: none; color-scheme: dark;">
                            </div>
                            <div style="flex: 1;">
                                <label style="display: block; margin-bottom: 8px; color: var(--text-muted);">重复周期</label>
                                <select id="task-recurrence" style="width: 100%; padding: 12px; border-radius: 8px; background: rgba(255,255,255,0.1); border: 1px solid var(--glass-border); color: white; outline: none;">
                                    <option value="once" style="color: black;">单次执行</option>
                                    <option value="daily" style="color: black;">每天</option>
                                    <option value="weekly" style="color: black;">每周</option>
                                    <option value="monthly" style="color: black;">每月</option>
                                </select>
                            </div>
                        </div>

                        <button class="btn" onclick="createTask(this)">
                            <i class="fa-solid fa-bolt"></i> 创建推送计划
                        </button>
                    </div>
                </div>

                <!-- 推送任务列表 -->
                <div class="glass-card">
                    <h3>推送任务列表</h3>
                    <div id="task-list" class="data-list">
                        <div class="list-item">
                            <div class="item-info">
                                <h4>暂无推送任务</h4>
                                <p>请在上方创建新的推送计划</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 智能推送日历 -->
                <div class="glass-card">
                    <h3>智能推送日历</h3>
                    <div style="position: relative; padding-left: 20px; border-left: 2px solid var(--glass-border); margin-top: 20px;">
                        <div style="position: relative; margin-bottom: 25px;">
                            <div style="position: absolute; left: -26px; top: 0; width: 10px; height: 10px; border-radius: 50%; background: var(--primary-color); box-shadow: 0 0 10px var(--primary-color);"></div>
                            <h4 style="margin-bottom: 5px;">入职前 3 天 (自动触发)</h4>
                            <p style="color: var(--text-muted); font-size: 14px; background: rgba(255,255,255,0.05); padding: 10px; border-radius: 8px; display: inline-block;">推送内容：《入职材料准备清单》、《公司周边交通及食宿指南》</p>
                        </div>
                        <div style="position: relative; margin-bottom: 25px;">
                            <div style="position: absolute; left: -26px; top: 0; width: 10px; height: 10px; border-radius: 50%; background: #ff9100; box-shadow: 0 0 10px #ff9100;"></div>
                            <h4 style="margin-bottom: 5px;">入职当天 09:00</h4>
                            <p style="color: var(--text-muted); font-size: 14px; background: rgba(255,255,255,0.05); padding: 10px; border-radius: 8px; display: inline-block;">推送内容：《系统账号激活流程》、《考勤与办公设备领用指引》</p>
                        </div>
                    </div>
                </div>
            </section>
            
        </main>
    </div>

    <script>
        // 侧边栏导航切换逻辑
        const navItems = document.querySelectorAll('.nav-item');
        const viewSections = document.querySelectorAll('.view-section');
        const pageTitle = document.getElementById('page-title');

        navItems.forEach(item => {
            item.addEventListener('click', () => {
                // 移除所有 active 类
                navItems.forEach(n => n.classList.remove('active'));
                viewSections.forEach(v => v.classList.remove('active'));

                // 为当前点击项添加 active
                item.classList.add('active');
                
                // 更改标题
                pageTitle.textContent = item.textContent.trim();

                // 显示对应的视图面板
                const targetId = item.getAttribute('data-target');
                document.getElementById(targetId).classList.add('active');
            });
        });

        // 流程知识库 - 文件上传功能
        const flowUploadArea = document.getElementById('drop-zone-flow');
        const fileInputFlow = document.getElementById('file-input-flow');
        const selectBtnFlow = document.getElementById('select-btn-flow');
        const uploadTitleFlow = document.getElementById('upload-title-flow');
        const uploadSubtitleFlow = document.getElementById('upload-subtitle-flow');
        const fileNameFlow = document.getElementById('file-name-flow');

        selectBtnFlow.addEventListener('click', () => {
            fileInputFlow.click();
        });

        fileInputFlow.addEventListener('change', (e) => {
            handleFlowFile(e.target.files[0]);
        });

        flowUploadArea.addEventListener('dragover', (e) => {
            e.preventDefault();
            flowUploadArea.classList.add('dragover');
        });

        flowUploadArea.addEventListener('dragleave', () => {
            flowUploadArea.classList.remove('dragover');
        });

        flowUploadArea.addEventListener('drop', (e) => {
            e.preventDefault();
            flowUploadArea.classList.remove('dragover');
            const file = e.dataTransfer.files[0];
            if (file) {
                handleFlowFile(file);
            }
        });

        function handleFlowFile(file) {
            if (!file) return;

            const validTypes = [
                'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet',
                'application/vnd.ms-excel',
                'text/csv'
            ];
            const validExtensions = ['.xlsx', '.xls', '.csv'];
            const fileExtension = file.name.substring(file.name.lastIndexOf('.')).toLowerCase();

            if (!validExtensions.includes(fileExtension)) {
                showUploadError('仅支持 .xlsx, .xls, .csv 格式文件');
                return;
            }

            if (file.size > 50 * 1024 * 1024) {
                showUploadError('文件大小超过 50MB 限制');
                return;
            }

            const icon = flowUploadArea.querySelector('i');
            icon.className = 'fa-solid fa-spinner fa-spin';
            icon.style.color = 'var(--primary-color)';
            uploadTitleFlow.textContent = '正在解析文件...';
            uploadSubtitleFlow.style.display = 'none';
            fileNameFlow.textContent = file.name + ' (' + formatFileSize(file.size) + ')';
            fileNameFlow.style.display = 'block';

            setTimeout(() => {
                icon.className = 'fa-solid fa-circle-check';
                icon.style.color = '#00e676';
                uploadTitleFlow.textContent = '文件解析成功！';
                fileNameFlow.style.display = 'none';

                setTimeout(() => {
                    icon.className = 'fa-solid fa-cloud-arrow-up';
                    icon.style.color = 'var(--primary-color)';
                    uploadTitleFlow.textContent = '点击或将文件拖拽到此处';
                    uploadSubtitleFlow.style.display = 'block';
                    fileInputFlow.value = '';
                }, 3000);
            }, 1500);
        }

        function showUploadError(message) {
            const icon = flowUploadArea.querySelector('i');
            const originalTitle = uploadTitleFlow.textContent;
            icon.className = 'fa-solid fa-circle-exclamation';
            icon.style.color = '#ff5252';
            uploadTitleFlow.textContent = message;

            setTimeout(() => {
                icon.className = 'fa-solid fa-cloud-arrow-up';
                icon.style.color = 'var(--primary-color)';
                uploadTitleFlow.textContent = originalTitle;
            }, 3000);
        }

        function formatFileSize(bytes) {
            if (bytes < 1024) return bytes + ' B';
            if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
            return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
        }

        // 其他上传区域（保留拖拽功能）
        const uploadAreas = document.querySelectorAll('.upload-area');
        
        uploadAreas.forEach(area => {
            if (area.id === 'drop-zone-flow') return;
            
            area.addEventListener('dragover', (e) => {
                e.preventDefault();
                area.classList.add('dragover');
            });

            area.addEventListener('dragleave', () => {
                area.classList.remove('dragover');
            });

            area.addEventListener('drop', (e) => {
                e.preventDefault();
                area.classList.remove('dragover');
                
                const icon = area.querySelector('i');
                const title = area.querySelector('h3');
                
                icon.className = 'fa-solid fa-circle-check';
                icon.style.color = '#00e676';
                title.textContent = '文件解析成功！';
                
                setTimeout(() => {
                    icon.className = 'fa-solid fa-file-excel';
                    icon.style.color = 'var(--primary-color)';
                    title.textContent = '继续拖拽文件至此';
                }, 3000);
            });
        });

        // 员工名单 - 文件上传功能
        const employeeUploadArea = document.getElementById('upload-area-employee');
        const fileInputEmployee = document.getElementById('file-input-employee');
        const selectBtnEmployee = document.getElementById('select-btn-employee');
        const uploadTitleEmployee = document.getElementById('upload-title-employee');
        const uploadSubtitleEmployee = document.getElementById('upload-subtitle-employee');
        const fileNameEmployee = document.getElementById('file-name-employee');

        selectBtnEmployee.addEventListener('click', () => {
            fileInputEmployee.click();
        });

        fileInputEmployee.addEventListener('change', (e) => {
            handleEmployeeFile(e.target.files[0]);
        });

        employeeUploadArea.addEventListener('dragover', (e) => {
            e.preventDefault();
            employeeUploadArea.classList.add('dragover');
        });

        employeeUploadArea.addEventListener('dragleave', () => {
            employeeUploadArea.classList.remove('dragover');
        });

        employeeUploadArea.addEventListener('drop', (e) => {
            e.preventDefault();
            employeeUploadArea.classList.remove('dragover');
            const file = e.dataTransfer.files[0];
            if (file) {
                handleEmployeeFile(file);
            }
        });

        const API_BASE = 'http://localhost:3000/api';

        function handleEmployeeFile(file) {
            if (!file) return;

            const validExtensions = ['.xlsx', '.xls', '.csv'];
            const fileExtension = file.name.substring(file.name.lastIndexOf('.')).toLowerCase();

            if (!validExtensions.includes(fileExtension)) {
                showEmployeeUploadError('仅支持 .xlsx, .xls, .csv 格式文件');
                return;
            }

            if (file.size > 50 * 1024 * 1024) {
                showEmployeeUploadError('文件大小超过 50MB 限制');
                return;
            }

            const icon = employeeUploadArea.querySelector('i');
            const btn = selectBtnEmployee;
            const originalBtnText = btn.innerHTML;

            icon.className = 'fa-solid fa-spinner fa-spin';
            icon.style.color = 'var(--primary-color)';
            uploadTitleEmployee.textContent = '正在上传文件...';
            uploadSubtitleEmployee.style.display = 'none';
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> 上传中...';
            btn.style.pointerEvents = 'none';
            fileNameEmployee.textContent = file.name + ' (' + formatFileSize(file.size) + ')';
            fileNameEmployee.style.display = 'block';

            const formData = new FormData();
            formData.append('file', file);

            fetch(`${API_BASE}/employees/upload`, {
                method: 'POST',
                body: formData
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    icon.className = 'fa-solid fa-circle-check';
                    icon.style.color = '#00e676';
                    uploadTitleEmployee.textContent = data.message || '名单导入成功！';
                    btn.innerHTML = '<i class="fa-solid fa-check"></i> 导入成功';
                    btn.style.background = 'linear-gradient(90deg, #00b09b, #96c93d)';
                    loadEmployeeList();
                } else {
                    throw new Error(data.error || '上传失败');
                }
            })
            .catch(err => {
                showEmployeeUploadError('上传失败: ' + err.message);
            })
            .finally(() => {
                setTimeout(() => {
                    icon.className = 'fa-solid fa-file-excel';
                    icon.style.color = 'var(--primary-color)';
                    uploadTitleEmployee.textContent = '拖拽员工名单表至此';
                    uploadSubtitleEmployee.style.display = 'block';
                    btn.innerHTML = originalBtnText;
                    btn.style.background = '';
                    btn.style.pointerEvents = 'auto';
                    fileNameEmployee.style.display = 'none';
                    fileInputEmployee.value = '';
                }, 3000);
            });
        }

        function showEmployeeUploadError(message) {
            const icon = employeeUploadArea.querySelector('i');
            const originalTitle = uploadTitleEmployee.textContent;
            icon.className = 'fa-solid fa-circle-exclamation';
            icon.style.color = '#ff5252';
            uploadTitleEmployee.textContent = message;

            setTimeout(() => {
                icon.className = 'fa-solid fa-file-excel';
                icon.style.color = 'var(--primary-color)';
                uploadTitleEmployee.textContent = originalTitle;
            }, 3000);
        }

        function loadEmployeeList() {
            const listEl = document.getElementById('employee-list');
            if (!listEl) return;

            fetch(`${API_BASE}/employees`)
                .then(res => res.json())
                .then(data => {
                    if (data.success && data.data.length > 0) {
                        listEl.innerHTML = data.data.map(emp => {
                            const flowCount = emp.matchedFlows ? emp.matchedFlows.length : 0;
                            return `
                                <div class="list-item" data-id="${emp.id}">
                                    <div class="item-info">
                                        <h4>${emp.name} - ${emp.position || '未设置岗位'}</h4>
                                        <p>部门：${emp.department || '未设置'} | 入职日期：${emp.hireDate || '未设置'}</p>
                                        <p style="font-size: 12px; color: var(--text-muted);">邮箱：${emp.email || '未设置'}</p>
                                    </div>
                                    <span class="badge">已匹配 ${flowCount} 个流程</span>
                                </div>
                            `;
                        }).join('');
                    } else {
                        listEl.innerHTML = `
                            <div class="list-item">
                                <div class="item-info">
                                    <h4>暂无待入职员工</h4>
                                    <p>请上传员工名单</p>
                                </div>
                            </div>
                        `;
                    }
                })
                .catch(err => {
                    console.error('加载员工列表失败:', err);
                });
        }

        loadEmployeeList();

        // ==================== 飞书机器人相关功能 ====================

        // 刷新飞书连接状态
        async function refreshFeishuStatus() {
            const statusEl = document.getElementById('feishu-status');
            try {
                const res = await fetch(`${API_BASE}/status`);
                const data = await res.json();
                if (data.success && data.data.connected) {
                    statusEl.textContent = '已连接';
                    statusEl.style.background = 'rgba(0,230,118,0.2)';
                    statusEl.style.color = '#00e676';
                } else {
                    statusEl.textContent = '未连接';
                    statusEl.style.background = 'rgba(255,100,100,0.2)';
                    statusEl.style.color = '#ff6b6b';
                }
            } catch (err) {
                statusEl.textContent = '离线';
                statusEl.style.background = 'rgba(255,100,100,0.2)';
                statusEl.style.color = '#ff6b6b';
            }
        }

        // 初始化时获取飞书状态
        refreshFeishuStatus();
        setInterval(refreshFeishuStatus, 30000);

        // 目标员工群切换
        document.getElementById('task-target').addEventListener('change', function() {
            const deptContainer = document.getElementById('department-select-container');
            deptContainer.style.display = this.value === 'department' ? 'block' : 'none';
        });

        // 获取选中的流程
        function getSelectedFlows() {
            const checkboxes = document.querySelectorAll('#task-flows input[type="checkbox"]:checked');
            return Array.from(checkboxes).map(cb => cb.value);
        }

        // 创建推送任务
        async function createTask(btn) {
            const name = document.getElementById('task-name').value.trim();
            const targetType = document.getElementById('task-target').value;
            const targetDepartment = document.getElementById('task-department').value;
            const scheduleTime = document.getElementById('task-time').value;
            const recurrence = document.getElementById('task-recurrence').value;

            if (!name) {
                alert('请输入计划名称');
                return;
            }
            if (!scheduleTime) {
                alert('请选择推送时间');
                return;
            }

            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> 创建中...';
            btn.style.pointerEvents = 'none';

            try {
                const res = await fetch(`${API_BASE}/tasks`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        name,
                        targetType,
                        targetDepartment: targetType === 'department' ? targetDepartment : null,
                        scheduleTime,
                        recurrence
                    })
                });
                const data = await res.json();

                if (data.success) {
                    btn.innerHTML = '<i class="fa-solid fa-check"></i> 创建成功';
                    btn.style.background = 'linear-gradient(90deg, #00b09b, #96c93d)';
                    
                    // 清空表单
                    document.getElementById('task-name').value = '';
                    document.getElementById('task-time').value = '';
                    
                    // 刷新任务列表
                    loadTaskList();
                } else {
                    alert('创建失败: ' + (data.error || '未知错误'));
                    btn.innerHTML = originalText;
                    btn.style.background = '';
                }
            } catch (err) {
                alert('请求失败: ' + err.message);
                btn.innerHTML = originalText;
                btn.style.background = '';
            }

            setTimeout(() => {
                btn.innerHTML = originalText;
                btn.style.background = '';
                btn.style.pointerEvents = 'auto';
            }, 2000);
        }

        // 加载任务列表
        async function loadTaskList() {
            const listEl = document.getElementById('task-list');
            
            try {
                const res = await fetch(`${API_BASE}/tasks`);
                const data = await res.json();
                
                if (!data.success || data.data.length === 0) {
                    listEl.innerHTML = `
                        <div class="list-item">
                            <div class="item-info">
                                <h4>暂无推送任务</h4>
                                <p>请在上方创建新的推送计划</p>
                            </div>
                        </div>
                    `;
                    return;
                }

                listEl.innerHTML = data.data.map(task => {
                    const statusBadge = task.status === 'pending' 
                        ? `<span class="badge" style="color: #ff9100; border-color: rgba(255,145,0,0.3); background: rgba(255,145,0,0.1);">等待执行</span>`
                        : `<span class="badge" style="color: #00e676; border-color: rgba(0,230,118,0.3); background: rgba(0,230,118,0.1);">已完成</span>`;
                    
                    const recurrenceText = {
                        'once': '单次',
                        'daily': '每日',
                        'weekly': '每周',
                        'monthly': '每月'
                    }[task.recurrence] || '单次';

                    const timeStr = new Date(task.scheduleTime).toLocaleString('zh-CN');
                    const flowCount = task.flows ? task.flows.length : 0;

                    return `
                        <div class="list-item" data-task-id="${task.id}">
                            <div class="item-info">
                                <h4>${task.name}</h4>
                                <p>${timeStr} | ${recurrenceText} | ${flowCount}个流程</p>
                            </div>
                            <div style="display: flex; align-items: center; gap: 10px;">
                                ${task.status === 'pending' ? `
                                    <button class="btn" style="padding: 8px 16px; font-size: 13px;" onclick="triggerTask('${task.id}', this)">
                                        <i class="fa-solid fa-paper-plane"></i> 立即推送
                                    </button>
                                ` : ''}
                                <button class="btn" style="padding: 8px 16px; font-size: 13px; background: linear-gradient(90deg, #ff6b6b, #ff8e53);" onclick="deleteTask('${task.id}', this)">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </div>
                            ${statusBadge}
                        </div>
                    `;
                }).join('');
            } catch (err) {
                listEl.innerHTML = `
                    <div class="list-item">
                        <div class="item-info">
                            <h4>无法加载任务</h4>
                            <p>请确保后端服务已启动 (localhost:3000)</p>
                        </div>
                    </div>
                `;
            }
        }

        // 删除任务
        async function deleteTask(taskId, btn) {
            if (!confirm('确定要删除这个推送任务吗？')) return;

            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';
            btn.style.pointerEvents = 'none';

            try {
                const res = await fetch(`${API_BASE}/tasks/${taskId}`, { method: 'DELETE' });
                const data = await res.json();
                
                if (data.success) {
                    loadTaskList();
                } else {
                    alert('删除失败');
                    btn.innerHTML = originalText;
                }
            } catch (err) {
                alert('请求失败: ' + err.message);
                btn.innerHTML = originalText;
            }

            btn.style.pointerEvents = 'auto';
        }

        // 手动触发任务
        async function triggerTask(taskId, btn) {
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';
            btn.style.pointerEvents = 'none';

            try {
                const res = await fetch(`${API_BASE}/tasks/${taskId}/trigger`, { method: 'POST' });
                const data = await res.json();
                
                if (data.success) {
                    btn.innerHTML = '<i class="fa-solid fa-check"></i> 已发送';
                    btn.style.background = 'linear-gradient(90deg, #00b09b, #96c93d)';
                    setTimeout(loadTaskList, 2000);
                } else {
                    alert('发送失败');
                    btn.innerHTML = originalText;
                }
            } catch (err) {
                alert('请求失败: ' + err.message);
                btn.innerHTML = originalText;
            }

            setTimeout(() => {
                btn.style.pointerEvents = 'auto';
            }, 2000);
        }

        // 页面加载时获取任务列表
        loadTaskList();
    </script>
</body>
</html>