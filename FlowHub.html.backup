<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HR Flow - 智能流程推送系统</title>
    <!-- 引入字体图标 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
	:root {
            --glass-bg: rgba(255, 255, 255, 0.05);
            --glass-border: rgba(255, 255, 255, 0.1);
            --glass-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
            --primary-color: #2dd4bf; /* 现代青色 */
            --secondary-color: #3b82f6; /* 商务蓝 */
            --text-main: #ffffff;
            --text-muted: #94a3b8;
        }

        body {
            background-color: #030712;
            color: var(--text-main);
            height: 100vh;
            overflow: hidden;
            display: flex;
            justify-content: center;
            align-items: center;
            position: relative;
        }

        .bg-shapes {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            overflow: hidden;
            z-index: -1;
            background: radial-gradient(circle at top right, #111827, #030712);
        }

        .shape {
            position: absolute;
            filter: blur(100px);
            border-radius: 50%;
            animation: float 20s infinite alternate linear;
            opacity: 0.4;
        }

        .shape-1 { width: 500px; height: 500px; background: #1e40af; top: -10%; left: -5%; }
        .shape-2 { width: 600px; height: 600px; background: #0f766e; bottom: -10%; right: -5%; }
        .shape-3 { width: 400px; height: 400px; background: #312e81; top: 30%; left: 30%; }

        @keyframes float {
            0% { transform: translate(0, 0) scale(1); }
            50% { transform: translate(100px, 50px) scale(1.2); }
            100% { transform: translate(-50px, 100px) scale(0.8); }
        }

        /* 核心布局结构 */
        .app-container {
            width: 90%;
            height: 90%;
            max-width: 1400px;
            display: flex;
            background: var(--glass-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            box-shadow: var(--glass-shadow);
            overflow: hidden;
            animation: slideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            opacity: 0;
            transform: translateY(30px);
        }

        @keyframes slideUp {
            to { opacity: 1; transform: translateY(0); }
        }

        /* 侧边栏 */
        .sidebar {
            width: 260px;
            border-right: 1px solid var(--glass-border);
            padding: 30px 20px;
            display: flex;
            flex-direction: column;
        }

        .logo {
            font-size: 24px;
            font-weight: bold;
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 50px;
            background: linear-gradient(to right, var(--primary-color), var(--secondary-color));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .nav-item {
            padding: 15px 20px;
            margin-bottom: 10px;
            border-radius: 12px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 15px;
            font-size: 16px;
            color: var(--text-muted);
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .nav-item:hover {
            color: var(--text-main);
            background: rgba(255, 255, 255, 0.05);
            transform: translateX(5px);
        }

        .nav-item.active {
            color: var(--text-main);
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid var(--glass-border);
            box-shadow: inset 0 0 10px rgba(255, 255, 255, 0.05);
        }

        .nav-item.active::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            height: 100%;
            width: 4px;
            background: linear-gradient(to bottom, var(--primary-color), var(--secondary-color));
        }

        /* 主内容区 */
        .main-content {
            flex: 1;
            padding: 40px;
            overflow-y: auto;
            position: relative;
        }

        /* 页面视图切换 */
        .view-section {
            display: none;
            animation: fadeIn 0.5s ease forwards;
        }

        .view-section.active {
            display: block;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
        }

        .header h1 {
            font-size: 28px;
            font-weight: 600;
        }

        .user-profile {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .avatar {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            display: flex;
            justify-content: center;
            align-items: center;
            font-weight: bold;
            box-shadow: 0 0 15px rgba(0, 242, 254, 0.4);
        }

        /* 卡片面板通用样式 */
        .glass-card {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--glass-border);
            border-radius: 20px;
            padding: 30px;
            margin-bottom: 30px;
            transition: transform 0.3s, box-shadow 0.3s;
        }

        .glass-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
            background: rgba(255, 255, 255, 0.06);
        }

        /* 上传拖拽区域 */
        .upload-area {
            border: 2px dashed rgba(255, 255, 255, 0.2);
            border-radius: 16px;
            padding: 50px 20px;
            text-align: center;
            transition: all 0.3s ease;
            cursor: pointer;
            background: rgba(0, 0, 0, 0.1);
        }

        .upload-area:hover, .upload-area.dragover {
            border-color: var(--primary-color);
            background: rgba(0, 242, 254, 0.05);
            box-shadow: inset 0 0 20px rgba(0, 242, 254, 0.1);
        }

        .upload-area i {
            font-size: 48px;
            color: var(--primary-color);
            margin-bottom: 20px;
            transition: transform 0.3s;
        }

        .upload-area:hover i {
            transform: scale(1.1) translateY(-5px);
        }

        .upload-area h3 { margin-bottom: 10px; font-weight: 500; }
        .upload-area p { color: var(--text-muted); font-size: 14px; margin-bottom: 20px; }

        /* 按钮样式 */
        .btn {
            background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));
            border: none;
            padding: 12px 30px;
            border-radius: 30px;
            color: white;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 5px 15px rgba(0, 242, 254, 0.3);
            display: inline-flex;
            align-items: center;
            gap: 10px;
        }

        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(0, 242, 254, 0.5);
            filter: brightness(1.1);
        }

        /* 列表/表格样式 */
        .data-list {
            margin-top: 20px;
        }
        
        .list-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 20px;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            transition: background 0.3s;
            border-radius: 10px;
        }

        .list-item:hover {
            background: rgba(255, 255, 255, 0.05);
        }

        .item-info h4 { font-size: 16px; margin-bottom: 5px; }
        .item-info p { font-size: 13px; color: var(--text-muted); }
        .badge {
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 12px;
            background: rgba(0, 242, 254, 0.1);
            color: var(--primary-color);
            border: 1px solid rgba(0, 242, 254, 0.3);
        }

        /* 数据概览小卡片 (Grid) */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: linear-gradient(135deg, rgba(255,255,255,0.05), rgba(255,255,255,0.01));
            padding: 25px;
            border-radius: 20px;
            border: 1px solid var(--glass-border);
            position: relative;
            overflow: hidden;
        }

        .stat-card::after {
            content: '\f080';
            font-family: 'Font Awesome 6 Free';
            font-weight: 900;
            position: absolute;
            right: -10px;
            bottom: -20px;
            font-size: 80px;
            opacity: 0.05;
        }

        .stat-card:nth-child(2)::after { content: '\f0c0'; }
        .stat-card:nth-child(3)::after { content: '\f1d8'; }

        .stat-value { font-size: 36px; font-weight: bold; margin-top: 10px; color: var(--primary-color); }

        /* 自定义滚动条 */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.2); border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.3); }

    </style>
</head>
<body>

    <!-- 动态背景层 -->
    <div class="bg-shapes">
        <div class="shape shape-1"></div>
        <div class="shape shape-2"></div>
        <div class="shape shape-3"></div>
    </div>

    <!-- 主体拟态玻璃容器 -->
    <div class="app-container">
        
        <!-- 左侧导航 -->
        <aside class="sidebar">
            <div class="logo">
                <i class="fa-solid fa-layer-group"></i>
                <span>FlowHub</span>
            </div>
            
            <nav>
                <div class="nav-item active" data-target="dashboard">
                    <i class="fa-solid fa-house"></i> 控制台概览
                </div>
                <div class="nav-item" data-target="knowledge">
                    <i class="fa-solid fa-book-open"></i> 流程知识库
                </div>
                <div class="nav-item" data-target="employees">
                    <i class="fa-solid fa-users"></i> 员工名单管理
                </div>
                <div class="nav-item" data-target="push-tasks">
                    <i class="fa-solid fa-paper-plane"></i> 定时推送任务
                </div>
            </nav>
        </aside>

        <!-- 右侧内容区 -->
        <main class="main-content">
            
            <header class="header">
                <h1 id="page-title">控制台概览</h1>
                <div class="user-profile">
                    <span>HR - 李主管</span>
                    <div class="avatar">李</div>
                </div>
            </header>

            <!-- 视图 1：控制台 -->
            <section id="dashboard" class="view-section active">
                <div class="stats-grid">
                    <div class="stat-card glass-card">
                        <p class="text-muted">已入库流程</p>
                        <div class="stat-value">128</div>
                    </div>
                    <div class="stat-card glass-card">
                        <p class="text-muted">本月待入职员工</p>
                        <div class="stat-value">45</div>
                    </div>
                    <div class="stat-card glass-card">
                        <p class="text-muted">自动推送任务</p>
                        <div class="stat-value">12</div>
                    </div>
                </div>
                
                <div class="glass-card">
                    <h3>最近执行的任务</h3>
                    <div class="data-list">
                        <div class="list-item">
                            <div class="item-info">
                                <h4>推送：IT设备申请及领用流程</h4>
                                <p>执行时间：今天 09:00 | 目标人数：15人</p>
                            </div>
                            <span class="badge" style="color: #00e676; border-color: rgba(0, 230, 118, 0.3); background: rgba(0, 230, 118, 0.1);">已完成</span>
                        </div>
                        <div class="list-item">
                            <div class="item-info">
                                <h4>推送：企业文化培训指南</h4>
                                <p>执行时间：明天 10:00 | 目标人数：45人</p>
                            </div>
                            <span class="badge" style="color: #ff9100; border-color: rgba(255, 145, 0, 0.3); background: rgba(255, 145, 0, 0.1);">等待执行</span>
                        </div>
                    </div>
                </div>
            </section>

            <!-- 视图 2：流程知识库 -->
            <section id="knowledge" class="view-section">
                <div class="glass-card">
                    <h3>导入流程清单</h3>
                    <p style="color: var(--text-muted); margin: 10px 0 20px;">支持导入 Excel / CSV 格式的流程标准文件。</p>
                    <div class="upload-area" id="drop-zone-flow">
                        <i class="fa-solid fa-cloud-arrow-up"></i>
                        <h3>点击或将文件拖拽到此处</h3>
                        <p>支持 .xlsx, .csv 文件，最大 50MB</p>
                        <button class="btn"><i class="fa-solid fa-folder-open"></i> 选择文件</button>
                    </div>
                </div>

                <div class="glass-card">
                    <h3>当前系统流程清单 (节选)</h3>
                    <div class="data-list">
                        <div class="list-item">
                            <div class="item-info">
                                <h4>P-001: 新员工入职指引</h4>
                                <p>标签：入职, HR流程 | 适用对象：全体新员工</p>
                            </div>
                        </div>
                        <div class="list-item">
                            <div class="item-info">
                                <h4>P-002: 研发中心权限开通规范</h4>
                                <p>标签：IT, 研发 | 适用对象：研发部员工</p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- 视图 3：员工名单 -->
            <section id="employees" class="view-section">
                <div class="glass-card">
                    <h3>上传入职员工名单</h3>
                    <p style="color: var(--text-muted); margin: 10px 0 20px;">系统将自动识别部门与岗位，智能匹配对应流程。</p>
                    <div class="upload-area">
                        <i class="fa-solid fa-file-excel"></i>
                        <h3>拖拽员工名单表至此</h3>
                        <p>请确保包含：姓名、入职日期、部门、岗位、邮箱</p>
                        <button class="btn"><i class="fa-solid fa-upload"></i> 上传名单</button>
                    </div>
                </div>
                
                <div class="glass-card">
                    <h3>待入职队列</h3>
                    <div class="data-list">
                        <div class="list-item">
                            <div class="item-info">
                                <h4>张三 - 前端开发工程师</h4>
                                <p>部门：研发部 | 入职日期：2023-11-01</p>
                            </div>
                            <span class="badge">已匹配 5 个流程</span>
                        </div>
                        <div class="list-item">
                            <div class="item-info">
                                <h4>李四 - 财务专员</h4>
                                <p>部门：财务部 | 入职日期：2023-11-03</p>
                            </div>
                            <span class="badge">已匹配 3 个流程</span>
                        </div>
                    </div>
                </div>
            </section>

            <!-- 视图 4：定时推送任务 -->
            <section id="push-tasks" class="view-section">
                <div class="glass-card">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                        <div>
                            <h3>新建推送计划</h3>
                            <p style="color: var(--text-muted); margin-top: 5px;">通过邮件或企业微信自动触达入职员工</p>
                        </div>
                        <button class="btn" onclick="triggerPushAnimation(this)">
                            <i class="fa-solid fa-bolt"></i> 立即创建计划
                        </button>
                    </div>
                    
                    <div style="background: rgba(0,0,0,0.2); border-radius: 12px; padding: 20px; border: 1px solid rgba(255,255,255,0.05);">
                        <div style="display: flex; gap: 20px; margin-bottom: 15px;">
                            <div style="flex: 1;">
                                <label style="display: block; margin-bottom: 8px; color: var(--text-muted);">选择目标员工群</label>
                                <select style="width: 100%; padding: 12px; border-radius: 8px; background: rgba(255,255,255,0.1); border: 1px solid var(--glass-border); color: white; outline: none;">
                                    <option style="color: black;">11月研发部新员工 (12人)</option>
                                    <option style="color: black;">11月全体新员工 (45人)</option>
                                </select>
                            </div>
                            <div style="flex: 1;">
                                <label style="display: block; margin-bottom: 8px; color: var(--text-muted);">推送时间设定</label>
                                <input type="datetime-local" style="width: 100%; padding: 12px; border-radius: 8px; background: rgba(255,255,255,0.1); border: 1px solid var(--glass-border); color: white; outline: none; color-scheme: dark;">
                            </div>
                        </div>
                    </div>
                </div>

                <div class="glass-card">
                    <h3>智能推送日历</h3>
                    <!-- 模拟的一个很酷的日历或时间轴 UI -->
                    <div style="position: relative; padding-left: 20px; border-left: 2px solid var(--glass-border); margin-top: 20px;">
                        <div style="position: relative; margin-bottom: 25px;">
                            <div style="position: absolute; left: -26px; top: 0; width: 10px; height: 10px; border-radius: 50%; background: var(--primary-color); box-shadow: 0 0 10px var(--primary-color);"></div>
                            <h4 style="margin-bottom: 5px;">入职前 3 天 (自动触发)</h4>
                            <p style="color: var(--text-muted); font-size: 14px; background: rgba(255,255,255,0.05); padding: 10px; border-radius: 8px; display: inline-block;">推送内容：《入职材料准备清单》、《公司周边交通及食宿指南》</p>
                        </div>
                        <div style="position: relative; margin-bottom: 25px;">
                            <div style="position: absolute; left: -26px; top: 0; width: 10px; height: 10px; border-radius: 50%; background: #ff9100; box-shadow: 0 0 10px #ff9100;"></div>
                            <h4 style="margin-bottom: 5px;">入职当天 09:00</h4>
                            <p style="color: var(--text-muted); font-size: 14px; background: rgba(255,255,255,0.05); padding: 10px; border-radius: 8px; display: inline-block;">推送内容：《系统账号激活流程》、《考勤与办公设备领用指引》</p>
                        </div>
                    </div>
                </div>
            </section>
            
        </main>
    </div>

    <script>
        // 侧边栏导航切换逻辑
        const navItems = document.querySelectorAll('.nav-item');
        const viewSections = document.querySelectorAll('.view-section');
        const pageTitle = document.getElementById('page-title');

        navItems.forEach(item => {
            item.addEventListener('click', () => {
                // 移除所有 active 类
                navItems.forEach(n => n.classList.remove('active'));
                viewSections.forEach(v => v.classList.remove('active'));

                // 为当前点击项添加 active
                item.classList.add('active');
                
                // 更改标题
                pageTitle.textContent = item.textContent.trim();

                // 显示对应的视图面板
                const targetId = item.getAttribute('data-target');
                document.getElementById(targetId).classList.add('active');
            });
        });

        // 模拟拖拽上传的交互动效
        const uploadAreas = document.querySelectorAll('.upload-area');
        
        uploadAreas.forEach(area => {
            area.addEventListener('dragover', (e) => {
                e.preventDefault();
                area.classList.add('dragover');
            });

            area.addEventListener('dragleave', () => {
                area.classList.remove('dragover');
            });

            area.addEventListener('drop', (e) => {
                e.preventDefault();
                area.classList.remove('dragover');
                
                // 模拟酷炫的上传成功效果
                const icon = area.querySelector('i');
                const title = area.querySelector('h3');
                
                icon.className = 'fa-solid fa-circle-check';
                icon.style.color = '#00e676';
                title.textContent = '文件解析成功！';
                
                setTimeout(() => {
                    // 恢复原状
                    if(area.id === 'drop-zone-flow') {
                        icon.className = 'fa-solid fa-cloud-arrow-up';
                    } else {
                        icon.className = 'fa-solid fa-file-excel';
                    }
                    icon.style.color = 'var(--primary-color)';
                    title.textContent = '继续拖拽文件至此';
                }, 3000);
            });
        });

        // 按钮点击反馈动画
        function triggerPushAnimation(btn) {
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> 生成计划中...';
            btn.style.pointerEvents = 'none';
            
            setTimeout(() => {
                btn.innerHTML = '<i class="fa-solid fa-check"></i> 创建成功';
                btn.style.background = 'linear-gradient(90deg, #00b09b, #96c93d)';
                
                setTimeout(() => {
                    btn.innerHTML = originalText;
                    btn.style.background = '';
                    btn.style.pointerEvents = 'auto';
                }, 2000);
            }, 1500);
        }
    </script>
</body>
</html>