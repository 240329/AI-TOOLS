<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Resume AI Pro - 智能简历分析桌面端</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            /* 更深邃的暗黑背景，凸显发光元素 */
            --bg-color: #050505; 
            --glass-bg: rgba(22, 25, 35, 0.45);
            --glass-border: rgba(255, 255, 255, 0.08);
            --glass-highlight: rgba(255, 255, 255, 0.15);
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --accent-blue: #3b82f6;
            --accent-purple: #8b5cf6;
            --accent-glow: rgba(59, 130, 246, 0.5);
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            
            /* 升级版高质感拟态阴影 */
            --neu-out: 
                8px 8px 16px rgba(0,0,0,0.8), 
                -4px -4px 12px rgba(255,255,255,0.03),
                inset 1px 1px 1px rgba(255,255,255,0.05);
            --neu-in: 
                inset 6px 6px 12px rgba(0,0,0,0.8), 
                inset -4px -4px 10px rgba(255,255,255,0.02);
            --neu-btn: 
                4px 4px 10px rgba(0,0,0,0.6), 
                -2px -2px 8px rgba(255,255,255,0.04);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', -apple-system, BlinkMacSystemFont, Roboto, sans-serif; }

        body {
            background-color: var(--bg-color); color: var(--text-main); height: 100vh;
            display: flex; align-items: center; justify-content: center; overflow: hidden; position: relative;
            background-image: radial-gradient(rgba(255,255,255,0.03) 1px, transparent 1px);
            background-size: 20px 20px;
        }

        .bg-shape { position: absolute; border-radius: 50%; filter: blur(90px); z-index: -1; animation: float 20s infinite alternate ease-in-out; opacity: 0.6; }
        .shape1 { width: 500px; height: 500px; background: #3b82f6; top: -15%; left: -5%; }
        .shape2 { width: 600px; height: 400px; background: #8b5cf6; bottom: -10%; right: -10%; animation-delay: -7s; }
        .shape3 { width: 400px; height: 400px; background: #0ea5e9; top: 30%; left: 30%; animation-delay: -12s; mix-blend-mode: screen; }

        @keyframes float { 0% { transform: translate(0, 0) scale(1) rotate(0deg); } 100% { transform: translate(60px, 80px) scale(1.1) rotate(15deg); } }

        .app-container {
            width: 92vw; height: 88vh; max-width: 1500px;
            background: var(--glass-bg);
            backdrop-filter: blur(25px) saturate(120%);
            -webkit-backdrop-filter: blur(25px) saturate(120%);
            border: 1px solid var(--glass-border);
            border-radius: 20px; box-shadow: 0 30px 60px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,255,255,0.1);
            display: flex; flex-direction: column; overflow: hidden;
        }

        .title-bar {
            height: 40px; background: rgba(0,0,0,0.2); border-bottom: 1px solid var(--glass-border);
            display: flex; align-items: center; padding: 0 20px; gap: 8px; flex-shrink: 0;
        }
        .mac-dot { width: 12px; height: 12px; border-radius: 50%; box-shadow: var(--neu-btn); cursor: pointer; }
        .dot-close { background: #ff5f56; } .dot-min { background: #ffbd2e; } .dot-max { background: #27c93f; }
        .title-text { flex: 1; text-align: center; font-size: 13px; color: var(--text-muted); font-weight: 500; letter-spacing: 1px; }

        .app-body { display: flex; flex: 1; overflow: hidden; }

        .sidebar {
            width: 260px; border-right: 1px solid var(--glass-border); padding: 30px 20px;
            display: flex; flex-direction: column; background: rgba(0,0,0,0.15); z-index: 10;
        }
        .logo { font-size: 22px; font-weight: 800; display: flex; align-items: center; gap: 12px; margin-bottom: 40px; background: linear-gradient(90deg, var(--accent-blue), var(--accent-purple)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .nav-menu { list-style: none; display: flex; flex-direction: column; gap: 12px; }
        .nav-item {
            padding: 14px 18px; border-radius: 12px; cursor: pointer; display: flex; align-items: center; gap: 15px;
            color: var(--text-muted); transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            background: transparent; border: 1px solid transparent; font-size: 14px; font-weight: 500;
        }
        .nav-item:hover { color: var(--text-main); background: rgba(255,255,255,0.03); }
        .nav-item.active {
            color: var(--accent-blue); box-shadow: var(--neu-in);
            background: rgba(0,0,0,0.2); border: 1px solid var(--glass-border);
        }
        
        .system-status {
            margin-top: auto; padding: 15px; border-radius: 16px; box-shadow: var(--neu-in);
            background: rgba(0,0,0,0.2); border: 1px solid var(--glass-border);
        }
        .status-title { font-size: 12px; color: var(--text-muted); margin-bottom: 8px; display:flex; justify-content:space-between; }
        .status-bar { height: 4px; background: rgba(255,255,255,0.1); border-radius: 2px; overflow: hidden; }
        .status-fill { height: 100%; width: 75%; background: linear-gradient(90deg, var(--accent-purple), var(--accent-blue)); box-shadow: 0 0 10px var(--accent-glow); }

        .main-content { flex: 1; padding: 30px 40px; display: flex; flex-direction: column; overflow-y: auto; position: relative; }
        .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
        .header h1 { font-size: 26px; font-weight: 600; text-shadow: 0 2px 4px rgba(0,0,0,0.5); }
        .header-tools { display: flex; align-items: center; gap: 20px; }
        .tool-btn {
            width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center;
            background: rgba(255,255,255,0.03); border: 1px solid var(--glass-border); box-shadow: var(--neu-btn);
            color: var(--text-muted); cursor: pointer; transition: 0.3s;
        }
        .tool-btn:hover { color: var(--accent-blue); box-shadow: var(--neu-in); }
        .user-profile { width: 42px; height: 42px; border-radius: 50%; background: url('https://api.dicebear.com/6.x/avataaars/svg?seed=Felix') center/cover; box-shadow: var(--neu-out); border: 2px solid var(--glass-border); }

        .view-section { display: none; flex-direction: column; gap: 25px; animation: slideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
        .view-section.active { display: flex; }
        @keyframes slideUp { from { opacity: 0; transform: translateY(15px); } to { opacity: 1; transform: translateY(0); } }

        .glass-card {
            background: rgba(255,255,255,0.02); border: 1px solid var(--glass-border);
            border-radius: 20px; padding: 25px; box-shadow: var(--neu-out); position: relative; overflow: hidden;
        }

        .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
        .stat-icon-wrapper { width: 50px; height: 50px; border-radius: 14px; background: rgba(0,0,0,0.2); display: flex; align-items: center; justify-content: center; font-size: 22px; box-shadow: var(--neu-in); margin-bottom: 15px; }
        .stat-value { font-size: 36px; font-weight: 700; font-family: 'Courier New', Courier, monospace; margin-bottom: 5px; }
        
        /* 简历导入样式 */
        .upload-container {
            display: flex;
            flex-direction: column;
            gap: 25px;
        }

        .upload-area {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 50px 20px;
            border-radius: 24px;
            border: 2px dashed var(--glass-border);
            background: rgba(0,0,0,0.2);
            box-shadow: var(--neu-in);
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
        }

        .upload-area:hover,
        .upload-area.dragover {
            border-color: var(--accent-blue);
            background: rgba(59, 130, 246, 0.08);
            box-shadow: 0 0 30px rgba(59, 130, 246, 0.2), var(--neu-in);
        }

        .upload-area.dragover {
            transform: scale(1.02);
        }

        .upload-icon {
            font-size: 60px;
            color: var(--accent-blue);
            margin-bottom: 20px;
            filter: drop-shadow(0 0 15px var(--accent-glow));
            animation: floatIcon 3s ease-in-out infinite;
        }

        @keyframes floatIcon {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }

        .upload-area h2 { margin-bottom: 10px; }
        .upload-area p { color: var(--text-muted); font-size: 14px; margin-bottom: 20px; }

        .upload-btn {
            padding: 12px 30px;
            border-radius: 30px;
            border: none;
            background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
            color: white;
            cursor: pointer;
            box-shadow: var(--neu-btn), 0 0 20px rgba(59, 130, 246, 0.3);
            transition: all 0.3s ease;
            font-size: 15px;
            font-weight: 500;
        }

        .upload-btn:hover {
            transform: translateY(-2px);
            box-shadow: var(--neu-btn), 0 5px 30px rgba(59, 130, 246, 0.5);
        }

        /* 文件列表样式 */
        .file-list-container {
            display: none;
        }

        .file-list-container.active {
            display: block;
        }

        .file-list-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }

        .file-list-header h3 {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .file-count {
            background: var(--accent-blue);
            color: white;
            padding: 2px 10px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: normal;
        }

        .file-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
            max-height: 300px;
            overflow-y: auto;
        }

        .file-item {
            display: flex;
            align-items: center;
            gap: 15px;
            padding: 15px;
            background: rgba(0,0,0,0.3);
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.05);
            transition: all 0.3s ease;
        }

        .file-item:hover {
            border-color: rgba(255,255,255,0.1);
            background: rgba(0,0,0,0.4);
        }

        .file-icon {
            width: 45px;
            height: 45px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            flex-shrink: 0;
        }

        .file-icon.pdf { background: rgba(239, 68, 68, 0.2); color: #ef4444; }
        .file-icon.doc { background: rgba(59, 130, 246, 0.2); color: #3b82f6; }
        .file-icon.docx { background: rgba(59, 130, 246, 0.2); color: #3b82f6; }

        .file-info {
            flex: 1;
            min-width: 0;
        }

        .file-name {
            font-size: 14px;
            font-weight: 500;
            margin-bottom: 4px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .file-meta {
            font-size: 12px;
            color: var(--text-muted);
            display: flex;
            gap: 15px;
        }

        .file-status {
            font-size: 12px;
            padding: 4px 12px;
            border-radius: 20px;
            flex-shrink: 0;
        }

        .file-status.pending {
            background: rgba(255,255,255,0.05);
            color: var(--text-muted);
        }

        .file-status.parsing {
            background: rgba(59, 130, 246, 0.2);
            color: var(--accent-blue);
            animation: pulse 1.5s ease-in-out infinite;
        }

        .file-status.done {
            background: rgba(16, 185, 129, 0.2);
            color: var(--success);
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.6; }
        }

        .file-remove {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            border: none;
            background: rgba(255,255,255,0.05);
            color: var(--text-muted);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
            flex-shrink: 0;
        }

        .file-remove:hover {
            background: rgba(239, 68, 68, 0.2);
            color: var(--danger);
        }

        /* 解析按钮 */
        .parse-actions {
            display: flex;
            justify-content: center;
            gap: 15px;
            margin-top: 10px;
        }

        .parse-btn {
            padding: 14px 40px;
            border-radius: 30px;
            border: none;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .parse-btn.primary {
            background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
            color: white;
            box-shadow: 0 5px 25px rgba(59, 130, 246, 0.4);
        }

        .parse-btn.primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 35px rgba(59, 130, 246, 0.5);
        }

        .parse-btn.primary:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }

        .parse-btn.secondary {
            background: rgba(255,255,255,0.05);
            color: var(--text-main);
            border: 1px solid var(--glass-border);
        }

        .parse-btn.secondary:hover {
            background: rgba(255,255,255,0.1);
        }

        /* 整体进度 */
        .overall-progress {
            display: none;
        }

        .overall-progress.active {
            display: block;
        }

        .progress-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }

        .progress-bar-container {
            height: 8px;
            background: rgba(0,0,0,0.4);
            border-radius: 4px;
            overflow: hidden;
            box-shadow: var(--neu-in);
        }

        .progress-bar-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--accent-blue), var(--accent-purple));
            border-radius: 4px;
            transition: width 0.3s ease;
            box-shadow: 0 0 15px var(--accent-glow);
        }

        .progress-stats {
            display: flex;
            justify-content: center;
            gap: 40px;
            margin-top: 15px;
            font-size: 14px;
            color: var(--text-muted);
        }

        .progress-stats span {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .progress-stats i {
            color: var(--accent-blue);
        }

        /* 搜索样式 */
        .search-wrapper { position: relative; width: 100%; box-shadow: var(--neu-in); border-radius: 16px; background: rgba(0,0,0,0.2); }
        .search-wrapper i { position: absolute; left: 20px; top: 50%; transform: translateY(-50%); color: var(--accent-blue); font-size: 18px; }
        .search-bar { width: 100%; padding: 18px 20px 18px 50px; background: transparent; border: none; color: white; font-size: 16px; outline: none; }
        
        .candidate-card { transition: 0.3s; }
        .candidate-card:hover { border-color: var(--accent-blue); transform: translateY(-3px); }
        .skill-tag { background: rgba(0,0,0,0.3); padding: 4px 10px; border-radius: 8px; font-size: 12px; color: var(--accent-purple); border: 1px solid rgba(139, 92, 246, 0.3); }
        .ai-insight { margin-top: 15px; padding: 12px 15px; background: rgba(59, 130, 246, 0.1); border-left: 3px solid var(--accent-blue); border-radius: 0 8px 8px 0; font-size: 13px; color: var(--text-main); display: flex; gap: 10px; align-items: flex-start; }

        .category-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
        .folder-card { text-align: center; cursor: pointer; transition: 0.3s; }
        .folder-card:hover { transform: translateY(-5px); box-shadow: 0 20px 40px rgba(0,0,0,0.8), var(--neu-out); }
        .avatars-overlap { display: flex; justify-content: center; margin-top: 15px; }
        .avatars-overlap img { width: 30px; height: 30px; border-radius: 50%; border: 2px solid #1e222d; margin-left: -10px; }
        .avatars-overlap img:first-child { margin-left: 0; }

        .chart-layout { display: grid; grid-template-columns: 2fr 1fr; gap: 20px; }
        .donut-chart {
            width: 180px; height: 180px; border-radius: 50%; margin: 0 auto 20px;
            background: conic-gradient( var(--accent-blue) 0% 45%, var(--accent-purple) 45% 75%, var(--success) 75% 90%, var(--warning) 90% 100% );
            position: relative; box-shadow: var(--neu-out); display: flex; align-items: center; justify-content: center;
        }
        .donut-inner { width: 120px; height: 120px; background: #161923; border-radius: 50%; box-shadow: var(--neu-in); display: flex; flex-direction: column; align-items: center; justify-content: center; }

        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.15); border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--accent-blue); }

        /* 结果弹窗样式 */
        .result-modal {
            position: fixed;
            inset: 0;
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }
        .result-modal.active { display: flex; }

        .modal-backdrop {
            position: absolute;
            inset: 0;
            background: rgba(0,0,0,0.7);
            backdrop-filter: blur(10px);
        }

        .modal-content {
            position: relative;
            background: rgba(22,25,35,0.95);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            padding: 40px 50px;
            text-align: center;
            animation: modalIn 0.3s ease;
        }

        @keyframes modalIn {
            from { opacity: 0; transform: scale(0.9); }
            to { opacity: 1; transform: scale(1); }
        }

        .modal-icon {
            width: 70px;
            height: 70px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            font-size: 30px;
        }
        .modal-icon.success {
            background: rgba(16,185,129,0.2);
            color: var(--success);
        }

        .modal-content h2 {
            font-size: 24px;
            margin-bottom: 10px;
        }
        .modal-content p { color: var(--text-muted); }
        .modal-content strong { color: var(--accent-blue); }
        .modal-content .hint { font-size: 13px; margin-top: 5px; }

        .modal-btn {
            margin-top: 25px;
            padding: 12px 40px;
            background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
            border: none;
            border-radius: 25px;
            color: white;
            font-size: 15px;
            cursor: pointer;
            transition: 0.3s;
        }
        .modal-btn:hover { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(59,130,246,0.4); }
    </style>
</head>
<body>

    <div class="bg-shape shape1"></div>
    <div class="bg-shape shape2"></div>
    <div class="bg-shape shape3"></div>

    <!-- 解析完成弹窗 -->
    <div class="result-modal" id="result-modal">
        <div class="modal-backdrop"></div>
        <div class="modal-content">
            <div class="modal-icon success">
                <i class="fa-solid fa-check"></i>
            </div>
            <h2>解析完成</h2>
            <p>成功处理 <strong id="modal-count">0</strong> 份简历</p>
            <p class="hint">解析结果已输出到控制台</p>
            <button class="modal-btn" onclick="closeResultModal()">确定</button>
        </div>
    </div>

    <div class="app-container">
        <div class="title-bar">
            <div class="mac-dot dot-close"></div>
            <div class="mac-dot dot-min"></div>
            <div class="mac-dot dot-max"></div>
            <div class="title-text">Resume AI Pro - Enterprise Edition</div>
        </div>

        <div class="app-body">
            <aside class="sidebar">
                <div class="logo">
                    <i class="fa-solid fa-brain"></i>
                    <span>Resume AI</span>
                </div>
                <ul class="nav-menu">
                    <li class="nav-item active" data-target="dashboard"><i class="fa-solid fa-house"></i><span>工作台总览</span></li>
                    <li class="nav-item" data-target="import"><i class="fa-solid fa-cloud-arrow-up"></i><span>简历解析舱</span></li>
                    <li class="nav-item" data-target="filter"><i class="fa-solid fa-robot"></i><span>AI 智能推荐</span></li>
                    <li class="nav-item" data-target="categories"><i class="fa-solid fa-layer-group"></i><span>人才库管理</span></li>
                    <li class="nav-item" data-target="analytics"><i class="fa-solid fa-chart-pie"></i><span>数据大屏</span></li>
                </ul>

                <div class="system-status">
                    <div class="status-title">
                        <span><i class="fa-solid fa-server"></i> 大模型 API 额度</span>
                        <span style="color:var(--accent-blue);">75%</span>
                    </div>
                    <div class="status-bar"><div class="status-fill"></div></div>
                    <div style="font-size: 11px; color: var(--text-muted); margin-top: 8px; text-align: center;">GPT-4o 引擎已连接</div>
                </div>
            </aside>

            <main class="main-content">
                <header class="header">
                    <h1 id="page-title">工作台总览</h1>
                    <div class="header-tools">
                        <div class="tool-btn"><i class="fa-regular fa-bell"></i></div>
                        <div class="tool-btn"><i class="fa-solid fa-gear"></i></div>
                        <div class="user-profile"></div>
                    </div>
                </header>

                <!-- ================= 1. 总览区 ================= -->
                <div id="view-dashboard" class="view-section active">
                    <div class="stats-grid">
                        <div class="glass-card">
                            <div class="stat-icon-wrapper" style="color: var(--accent-blue);"><i class="fa-solid fa-file-lines"></i></div>
                            <div class="stat-value">12,482</div>
                            <div style="color: var(--text-muted); font-size: 13px;">企业人才库总储量</div>
                        </div>
                        <div class="glass-card">
                            <div class="stat-icon-wrapper" style="color: var(--accent-purple);"><i class="fa-solid fa-bolt"></i></div>
                            <div class="stat-value">342</div>
                            <div style="color: var(--text-muted); font-size: 13px;">今日 AI 解析数量</div>
                        </div>
                        <div class="glass-card">
                            <div class="stat-icon-wrapper" style="color: var(--success);"><i class="fa-solid fa-bullseye"></i></div>
                            <div class="stat-value">89%</div>
                            <div style="color: var(--text-muted); font-size: 13px;">岗位平均匹配度提升</div>
                        </div>
                        <div class="glass-card">
                            <div class="stat-icon-wrapper" style="color: var(--warning);"><i class="fa-solid fa-clock-rotate-left"></i></div>
                            <div class="stat-value">12</div>
                            <div style="color: var(--text-muted); font-size: 13px;">队列待处理任务</div>
                        </div>
                    </div>
                    
                    <div class="glass-card" style="flex: 1;">
                        <h3 style="margin-bottom: 20px; font-weight: 500;">系统实时日志</h3>
                        <div style="display:flex; flex-direction:column; gap:15px; font-size: 14px; color: var(--text-muted);">
                            <div style="display:flex; align-items:center; gap:15px;"><span style="width:10px;height:10px;border-radius:50%;background:var(--success);box-shadow:0 0 10px var(--success);"></span>[14:02] AI 成功为岗位 "高级算法工程师" 挖掘出 3 名潜藏候选人。</div>
                            <div style="display:flex; align-items:center; gap:15px;"><span style="width:10px;height:10px;border-radius:50%;background:var(--accent-blue);box-shadow:0 0 10px var(--accent-blue);"></span>[13:45] 批量导入 50 份 PDF 简历，结构化特征提取完成，耗时 4.2s。</div>
                            <div style="display:flex; align-items:center; gap:15px;"><span style="width:10px;height:10px;border-radius:50%;background:var(--warning);box-shadow:0 0 10px var(--warning);"></span>[12:30] 检测到候选人 "王五" 的工作经历时间线存在 6 个月的异常空白。</div>
                        </div>
                    </div>
                </div>

                <!-- ================= 2. 简历解析舱 ================= -->
                <div id="view-import" class="view-section">
                    <div class="upload-container">
                        <!-- 上传区域 -->
                        <div class="upload-area" id="upload-box">
                            <i class="fa-solid fa-cloud-arrow-up upload-icon"></i>
                            <h2>将简历拖拽至此，召唤 AI 解析</h2>
                            <p>支持批量拖入 PDF, DOCX (单次限额 100 份)</p>
                            <button class="upload-btn" onclick="openFilePicker()">
                                <i class="fa-solid fa-folder-open"></i>&nbsp;&nbsp;浏览本地文件
                            </button>
                            <input type="file" id="file-input" multiple accept=".pdf,.doc,.docx" style="display: none;">
                        </div>

                        <!-- 文件列表 -->
                        <div class="file-list-container glass-card" id="file-list-container">
                            <div class="file-list-header">
                                <h3><i class="fa-solid fa-file-medical"></i> 已选择的文件 <span class="file-count" id="file-count">0</span></h3>
                                <button class="parse-btn secondary" onclick="clearAllFiles()" style="padding: 8px 16px; font-size: 13px;">
                                    <i class="fa-solid fa-trash"></i> 清空
                                </button>
                            </div>
                            <div class="file-list" id="file-list"></div>
                            <div class="parse-actions" id="parse-actions">
                                <button class="parse-btn secondary" onclick="addMoreFiles()">
                                    <i class="fa-solid fa-plus"></i> 继续添加
                                </button>
                                <button class="parse-btn primary" id="start-parse-btn" onclick="startParsing()">
                                    <i class="fa-solid fa-wand-magic-sparkles"></i> 开始解析
                                </button>
                            </div>
                        </div>

                        <!-- 整体进度 -->
                        <div class="overall-progress glass-card" id="overall-progress">
                            <div class="progress-header">
                                <h3><i class="fa-solid fa-spinner fa-spin"></i>&nbsp;&nbsp;正在解析...</h3>
                                <span id="progress-percent">0%</span>
                            </div>
                            <div class="progress-bar-container">
                                <div class="progress-bar-fill" id="progress-fill" style="width: 0%;"></div>
                            </div>
                            <div class="progress-stats">
                                <span><i class="fa-solid fa-check-circle" style="color: var(--success);"></i> 已完成: <strong id="parsed-count">0</strong></span>
                                <span><i class="fa-solid fa-hourglass-half"></i> 队列中: <strong id="pending-count">0</strong></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ================= 3. AI 智能推荐 ================= -->
                <div id="view-filter" class="view-section">
                    <div class="search-wrapper">
                        <i class="fa-solid fa-sparkles"></i>
                        <input type="text" class="search-bar" placeholder="告诉 AI 你的需求：找一个有5年以上 React 经验，做过 SaaS 产品，且在深圳的前端...">
                    </div>
                    
                    <div style="display: flex; flex-direction: column; gap: 20px;">
                        <div class="glass-card candidate-card">
                            <div style="display:flex; justify-content:space-between; align-items:flex-start;">
                                <div style="display:flex; gap: 20px;">
                                    <div class="user-profile" style="width:65px; height:65px; background-image:url('https://api.dicebear.com/6.x/avataaars/svg?seed=Jack'); border-radius: 16px;"></div>
                                    <div>
                                        <h2 style="font-size: 18px; margin-bottom: 6px;">陈明轩 - 资深前端架构师</h2>
                                        <div style="display:flex; gap:10px; margin-bottom: 10px;">
                                            <span class="skill-tag">React</span><span class="skill-tag">TypeScript</span><span class="skill-tag">SaaS架构</span>
                                        </div>
                                        <p style="font-size:13px; color:var(--text-muted);"><i class="fa-solid fa-briefcase"></i> 7年经验 | <i class="fa-solid fa-graduation-cap"></i> 电子科技大学 | <i class="fa-solid fa-location-dot"></i> 深圳</p>
                                    </div>
                                </div>
                                <div style="text-align: right;">
                                    <div style="font-size: 28px; font-weight: 800; color: var(--success); text-shadow: 0 0 15px rgba(16, 185, 129, 0.4);">96%</div>
                                    <div style="font-size: 12px; color: var(--text-muted);">综合匹配度</div>
                                </div>
                            </div>
                            <div class="ai-insight">
                                <i class="fa-solid fa-lightbulb" style="color: var(--accent-blue); margin-top: 2px;"></i>
                                <div>
                                    <b>AI 洞察：</b>该候选人曾在腾讯主导过类似 SaaS 项目的从零到一重构，其简历中多次提及的 "微前端方案" 与您的 JD 需求高度吻合。稳定性极佳（平均在职 3.5 年）。
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ================= 4. 人才库管理 ================= -->
                <div id="view-categories" class="view-section">
                    <div class="category-grid">
                        <div class="glass-card folder-card">
                            <i class="fa-solid fa-folder-open" style="font-size: 40px; color: var(--accent-blue); margin-bottom: 15px;"></i>
                            <h3 style="margin-bottom: 5px;">前端开发组</h3>
                            <p style="font-size: 13px; color: var(--text-muted);">共 156 份简历</p>
                            <div class="avatars-overlap">
                                <img src="https://api.dicebear.com/6.x/avataaars/svg?seed=1" alt="avatar">
                                <img src="https://api.dicebear.com/6.x/avataaars/svg?seed=2" alt="avatar">
                                <img src="https://api.dicebear.com/6.x/avataaars/svg?seed=3" alt="avatar">
                                <div style="width:30px; height:30px; border-radius:50%; background:rgba(0,0,0,0.5); border:2px solid #1e222d; margin-left:-10px; display:flex; align-items:center; justify-content:center; font-size:10px; color:white;">+153</div>
                            </div>
                        </div>
                        <div class="glass-card folder-card">
                            <i class="fa-solid fa-folder-open" style="font-size: 40px; color: var(--accent-purple); margin-bottom: 15px;"></i>
                            <h3 style="margin-bottom: 5px;">AI 算法团队</h3>
                            <p style="font-size: 13px; color: var(--text-muted);">共 89 份简历</p>
                            <div class="avatars-overlap">
                                <img src="https://api.dicebear.com/6.x/avataaars/svg?seed=4" alt="avatar">
                                <img src="https://api.dicebear.com/6.x/avataaars/svg?seed=5" alt="avatar">
                                <div style="width:30px; height:30px; border-radius:50%; background:rgba(0,0,0,0.5); border:2px solid #1e222d; margin-left:-10px; display:flex; align-items:center; justify-content:center; font-size:10px; color:white;">+87</div>
                            </div>
                        </div>
                        <div class="glass-card folder-card" style="border: 2px dashed var(--glass-border); background: rgba(0,0,0,0.2); box-shadow: var(--neu-in); display: flex; flex-direction: column; justify-content: center;">
                            <i class="fa-solid fa-plus" style="font-size: 30px; color: var(--text-muted); margin-bottom: 15px;"></i>
                            <h3>新建智能分类</h3>
                        </div>
                    </div>
                </div>

                <!-- ================= 5. 数据大屏 ================= -->
                <div id="view-analytics" class="view-section">
                    <div class="chart-layout">
                        <div class="glass-card">
                            <h3 style="margin-bottom: 30px;">简历来源渠道分析</h3>
                            <div style="display: flex; align-items: center; justify-content: space-around;">
                                <div class="donut-chart">
                                    <div class="donut-inner">
                                        <div style="font-size: 24px; font-weight: bold;">12K+</div>
                                        <div style="font-size: 12px; color: var(--text-muted);">总简历数</div>
                                    </div>
                                </div>
                                <div style="display: flex; flex-direction: column; gap: 15px;">
                                    <div style="display:flex; align-items:center; gap:10px;"><span style="width:12px;height:12px;border-radius:3px;background:var(--accent-blue);"></span> Boss直聘 (45%)</div>
                                    <div style="display:flex; align-items:center; gap:10px;"><span style="width:12px;height:12px;border-radius:3px;background:var(--accent-purple);"></span> 猎聘网 (30%)</div>
                                    <div style="display:flex; align-items:center; gap:10px;"><span style="width:12px;height:12px;border-radius:3px;background:var(--success);"></span> 内部推荐 (15%)</div>
                                    <div style="display:flex; align-items:center; gap:10px;"><span style="width:12px;height:12px;border-radius:3px;background:var(--warning);"></span> 其他渠道 (10%)</div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="glass-card" style="display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center;">
                            <i class="fa-solid fa-stopwatch" style="font-size: 40px; color: var(--success); margin-bottom: 15px;"></i>
                            <div style="font-size: 14px; color: var(--text-muted); margin-bottom: 5px;">本月 AI 累计为您节省</div>
                            <div style="font-size: 42px; font-weight: bold; font-family: 'Courier New'; color: var(--text-main); text-shadow: 0 0 15px rgba(255,255,255,0.3);">342 <span style="font-size: 18px; color: var(--text-muted);">小时</span></div>
                            <p style="font-size: 12px; color: var(--success); margin-top: 10px;">↑ 效率较人工提升 800%</p>
                        </div>
                    </div>
                </div>

            </main>
        </div>
    </div>

    <script>
        // 文件列表
        let selectedFiles = [];
        let isParsing = false;

        // DOM 元素
        const uploadBox = document.getElementById('upload-box');
        const fileInput = document.getElementById('file-input');
        const fileListContainer = document.getElementById('file-list-container');
        const fileList = document.getElementById('file-list');
        const fileCount = document.getElementById('file-count');
        const parseActions = document.getElementById('parse-actions');
        const overallProgress = document.getElementById('overall-progress');
        const progressFill = document.getElementById('progress-fill');
        const progressPercent = document.getElementById('progress-percent');
        const parsedCount = document.getElementById('parsed-count');
        const pendingCount = document.getElementById('pending-count');

        // 1. 侧边栏路由切换
        const navItems = document.querySelectorAll('.nav-item');
        const viewSections = document.querySelectorAll('.view-section');
        const pageTitle = document.getElementById('page-title');

        navItems.forEach(item => {
            item.addEventListener('click', () => {
                navItems.forEach(nav => nav.classList.remove('active'));
                viewSections.forEach(view => {
                    view.classList.remove('active');
                    view.style.animation = 'none';
                    view.offsetHeight;
                    view.style.animation = null;
                });

                item.classList.add('active');
                pageTitle.innerText = item.querySelector('span').innerText;

                const targetId = 'view-' + item.getAttribute('data-target');
                document.getElementById(targetId).classList.add('active');
            });
        });

        // 2. 打开文件选择器
        function openFilePicker() {
            fileInput.click();
        }

        // 3. 添加更多文件
        function addMoreFiles() {
            fileInput.click();
        }

        // 4. 处理文件选择
        fileInput.addEventListener('change', function(e) {
            handleFiles(this.files);
        });

        // 5. 拖拽事件
        uploadBox.addEventListener('dragover', function(e) {
            e.preventDefault();
            this.classList.add('dragover');
        });

        uploadBox.addEventListener('dragleave', function(e) {
            e.preventDefault();
            this.classList.remove('dragover');
        });

        uploadBox.addEventListener('drop', function(e) {
            e.preventDefault();
            this.classList.remove('dragover');
            handleFiles(e.dataTransfer.files);
        });

        // 6. 处理文件
        function handleFiles(files) {
            for (let file of files) {
                // 检查文件类型
                const ext = file.name.split('.').pop().toLowerCase();
                if (!['pdf', 'doc', 'docx'].includes(ext)) continue;
                
                // 检查是否已存在
                const exists = selectedFiles.some(f => f.name === file.name && f.size === file.size);
                if (!exists) {
                    selectedFiles.push(file);
                }
            }
            
            renderFileList();
            updateUI();
        }

        // 7. 渲染文件列表
        function renderFileList() {
            fileList.innerHTML = '';
            
            selectedFiles.forEach((file, index) => {
                const ext = file.name.split('.').pop().toLowerCase();
                const sizeKB = (file.size / 1024).toFixed(1);
                
                const item = document.createElement('div');
                item.className = 'file-item';
                item.innerHTML = `
                    <div class="file-icon ${ext}">
                        <i class="fa-solid fa-file-lines"></i>
                    </div>
                    <div class="file-info">
                        <div class="file-name">${file.name}</div>
                        <div class="file-meta">
                            <span>${sizeKB} KB</span>
                            <span>${ext.toUpperCase()}</span>
                        </div>
                    </div>
                    <span class="file-status pending" id="status-${index}">等待解析</span>
                    <button class="file-remove" onclick="removeFile(${index})" title="移除">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                `;
                fileList.appendChild(item);
            });

            fileCount.textContent = selectedFiles.length;
        }

        // 8. 更新UI状态
        function updateUI() {
            if (selectedFiles.length > 0) {
                uploadBox.style.display = 'none';
                fileListContainer.classList.add('active');
                overallProgress.classList.remove('active');
                parseActions.style.display = 'flex';
            } else {
                uploadBox.style.display = 'flex';
                fileListContainer.classList.remove('active');
                overallProgress.classList.remove('active');
            }
        }

        // 9. 移除单个文件
        function removeFile(index) {
            if (isParsing) return;
            selectedFiles.splice(index, 1);
            renderFileList();
            updateUI();
        }

        // 10. 清空所有文件
        function clearAllFiles() {
            if (isParsing) return;
            selectedFiles = [];
            renderFileList();
            updateUI();
        }

        // 11. 开始解析
        async function startParsing() {
            if (selectedFiles.length === 0 || isParsing) return;
            
            isParsing = true;
            document.getElementById('start-parse-btn').disabled = true;
            parseActions.style.display = 'none';
            overallProgress.classList.add('active');
            
            parsedCount.textContent = '0';
            pendingCount.textContent = selectedFiles.length;
            
            let completed = 0;
            
            for (let i = 0; i < selectedFiles.length; i++) {
                const statusEl = document.getElementById(`status-${i}`);
                statusEl.className = 'file-status parsing';
                statusEl.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> 解析中';
                
                // 模拟AI解析过程
                await simulateParsing();
                
                // 解析完成后输出到控制台
                console.log('=== 简历解析结果 ===');
                console.log('文件名:', selectedFiles[i].name);
                console.log('文件大小:', (selectedFiles[i].size / 1024).toFixed(2) + ' KB');
                console.log('文件类型:', selectedFiles[i].type || 'application/octet-stream');
                console.log('最后修改:', new Date(selectedFiles[i].lastModified).toLocaleString());
                
                // 模拟提取的简历信息
                const mockResult = {
                    fileName: selectedFiles[i].name,
                    extractedAt: new Date().toISOString(),
                    // 这里可以添加更多提取的信息
                };
                console.log('解析数据:', mockResult);
                console.log('===================');
                
                completed++;
                parsedCount.textContent = completed;
                pendingCount.textContent = selectedFiles.length - completed;
                
                const progress = Math.round((completed / selectedFiles.length) * 100);
                progressFill.style.width = progress + '%';
                progressPercent.textContent = progress + '%';
                
                statusEl.className = 'file-status done';
                statusEl.innerHTML = '<i class="fa-solid fa-check"></i> 已完成';
            }
            
            // 解析完成提示
            setTimeout(() => {
                showResultModal(completed);
            }, 500);
        }

        // 12. 模拟解析过程
        function simulateParsing() {
            return new Promise(resolve => {
                const duration = 800 + Math.random() * 1200; // 0.8-2秒
                setTimeout(resolve, duration);
            });
        }

        // 13. 显示结果弹窗
        function showResultModal(count) {
            document.getElementById('modal-count').textContent = count;
            document.getElementById('result-modal').classList.add('active');
        }

        // 14. 关闭结果弹窗
        function closeResultModal() {
            document.getElementById('result-modal').classList.remove('active');
            resetUpload();
        }

        // 15. 重置上传区域
        function resetUpload() {
            isParsing = false;
            selectedFiles = [];
            fileInput.value = '';
            renderFileList();
            updateUI();
            document.getElementById('start-parse-btn').disabled = false;
            progressFill.style.width = '0%';
            progressPercent.textContent = '0%';
        }
    </script>
</body>
</html>
